# ─────────────────────────────────────────────────────────────
# NeuralForge Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# NVIDIA NGC API Key (required for NIM container pulls)
# Get yours at: https://org.ngc.nvidia.com/setup
NGC_API_KEY=your-ngc-api-key-here

# NIM Model Image (default: Llama 3.1 8B Instruct)
NIM_MODEL=nvcr.io/nim/meta/llama-3.1-8b-instruct:latest

# ─── Optional Overrides ──────────────────────────────────────

# NeuralForge API
# PORT=8090
# HOST=0.0.0.0

# Embedding / Reranking
# EMBED_MODEL=embedding
# RERANK_MODEL=reranker
# EMBED_BATCH_SIZE=32
# EMBED_CACHE_TTL=300

# Qdrant
# QDRANT_COLLECTION=neuralforge

# Guardrails
# GUARDRAILS_ENABLED=true

# Discovery
# DISCOVERY_INTERVAL_HOURS=6
# DISCOVERY_PAIRS_PER_RUN=20
# DISCOVERY_CONFIDENCE_FLOOR=0.6

# Scraping
# SCRAPE_REQUEST_DELAY=1.5
# SCRAPE_REQUEST_TIMEOUT=15
